// Edit with `hyprshell config edit`
(
    version: 4,
    windows: (
        scale: 7.0,
        items_per_row: 7,
        overview: (
            launcher: (
                default_terminal: "ghostty",
                launch_modifier: "super",
                width: 700,
                max_items: 7,
                show_when_empty: true,
                plugins: (
                    applications: (
                        run_cache_weeks: 8,
                        show_execs: true,
                        show_actions_submenu: true,
                    ),
                    terminal: (),
                    shell: (),
                    websearch: (
                        engines: [
                            (
                                url: "https://www.google.com/search?q={}",
                                name: "Google",
                                key: 'g',
                            ),
                            (
                                url: "https://chatgpt.com/?q={}",
                                name: "ChatGpt",
                                key: 'c',
                            ),
                        ],
                    ),
                    calc: (),
                    path: (),
                    actions: (
                        actions: [
                            lock_screen,
                            hibernate,
                            logout,
                            reboot,
                            shutdown,
                            suspend,
                            custom(
                                names: [
                                    "Kill",
                                    "Stop",
                                ],
                                details: "Kill or stop a process by name",
                                command: "pkill \"{}\" && notify-send hyprshell \"stopped {}\"",
                                icon: "remove",
                            ),
                            custom(
                                names: [
                                    "Reload Hyprshell",
                                ],
                                details: "Reload Hyprshell",
                                command: "sleep 1; hyprshell socat \'\"Restart\"\'",
                                icon: "system-restart",
                            ),
                        ],
                    ),
                ),
            ),
            key: "Super_L",
            top_offset: 430,
            modifier: "super",
            filter_by: [],
            exclude_workspaces: "special:.*",
        ),
        switch: (
            modifier: "alt",
            key: "Tab",
            filter_by: [],
            switch_workspaces: false,
            exclude_workspaces: "",
            kill_key: 'q',
        ),
        switch_2: None,
    ),
)